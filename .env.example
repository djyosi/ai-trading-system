# App
APP_ENV=local
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://trading:trading@localhost:5432/trading

# Massive.com
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com

# Optional fallback data
ENABLE_YFINANCE_FALLBACK=true

# LLM explanation layer, optional for local MVP
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# IBKR paper, read-only/stub for MVP v1
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=7
IBKR_ACCOUNT_MODE=paper
ENABLE_IBKR=false

# Risk defaults
DEFAULT_RISK_PROFILE=moderate
MIN_PRICE=5.00
MIN_AVG_DAILY_VOLUME=750000
MIN_DOLLAR_VOLUME=10000000
MIN_RISK_REWARD=2.0
MAX_SPREAD_PERCENT=0.75
